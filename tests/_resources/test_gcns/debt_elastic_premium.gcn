assumptions
{
    positive
    {
        Y[], w[], R_star[];
    };
};

block HOUSEHOLD
{
    definitions
    {
        u[] = (C[] ^ (1 - sigma_C) / (1 - sigma_C));
        Phi_B[] = exp(-phi_B * (B[] / Y[] - B_bar));
    };

    controls
    {
        C[], B[];
    };

    objective
    {
        U[] = u[] + beta * E[][U[1]];
    };

    constraints
    {
        C[] + B[] = w[] + R_star[-1] * Phi_B[-1] * B[-1] : lambda[];
    };

    calibration
    {
        beta = 0.99;
        sigma_C = 2.0;
        phi_B = 0.01;
        B_bar = 0.0;
    };
};
